        "plt.figure(figsize=(12,4))\n",
        "plt.scatter(class0_centroids[:,0], class0_centroids[:,1], c='r', s=100)\n",
        "plt.scatter(class1_centroids[:,0], class1_centroids[:,1], c='b', s=100)\n",
        "plt.xlabel('Feature 1')\n",
        "plt.ylabel('Feature 2')\n",
        "plt.title('Centroids of the classes')\n",
        "plt.show()"
      ]
    },
